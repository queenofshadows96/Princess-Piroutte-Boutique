# Princess Pirouette Boutique - Local Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# ============================================
# Supabase Configuration (Database)
# ============================================
# Get these from https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ============================================
# Stripe Configuration (Payments)
# ============================================
# Get these from https://stripe.com (use test keys for development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# EmailJS Configuration (Email Notifications)
# ============================================
# Get these from https://www.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
